{
  "expo": {
    "name": "mobile_music_app",
    "slug": "mobile_music_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "musics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobilemusic",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.mobile_music_app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
  "expo-router",
  [
    "@react-native-google-signin/google-signin",
    {
      "iosUrlScheme": "com.googleusercontent.apps.472188167401-735m0071dlocoo3e416p2ik3scd991bb"
    }
  ],
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/logo.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  ],
  "expo-secure-store"
],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "API_URL": "http://172.20.10.7:3001", 
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8b91493e-d078-45b6-80b4-afc00d46ae10"
      }
    }
  }
}
